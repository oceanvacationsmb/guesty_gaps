GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Start with true. Change to false only after reviewing the proposed updates.
DRY_RUN=true

# Scan from today through this many days ahead.
SCAN_DAYS=180

# Time zone used to determine day 0.
APP_TIME_ZONE=America/New_York

# Safety cap for live mode. Keep at 1 for the first Guesty write test.
MAX_LIVE_UPDATES=1

# Protect the settings page and API with a private password.
SETTINGS_ADMIN_KEY=

# Fine-grained GitHub token with Contents: Read and write access to this repo.
# Used only to save the property selection in config/properties.json.
GITHUB_CONFIG_TOKEN=
GITHUB_CONFIG_OWNER=oceanvacationsmb
GITHUB_CONFIG_REPO=guesty_gaps
GITHUB_CONFIG_BRANCH=main
SETTINGS_PATH=config/properties.json
