GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Start with true. Change to false only after reviewing the proposed updates.
DRY_RUN=true

# Scan from today through this many days ahead.
SCAN_DAYS=180

# Safety cap for live mode. Keep at 1 for the first Guesty write test.
MAX_LIVE_UPDATES=1

# Protect the settings page and API with a private password.
SETTINGS_ADMIN_KEY=

# Optional fallback for Render services without a persistent disk.
# Listings are inactive by default. Add only the listing IDs you choose.
ACTIVE_LISTING_IDS=

# Optional persistent disk location, for example:
# SETTINGS_PATH=/var/data/guesty-gaps-settings.json
SETTINGS_PATH=.guesty-gaps-settings.json
