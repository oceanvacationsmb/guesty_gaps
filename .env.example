GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Start with true. Change to false only after reviewing the proposed updates.
DRY_RUN=true

# Scan from today through this many days ahead.
SCAN_DAYS=180

# Reopen only gaps up to this many nights long.
MAX_GAP_NIGHTS=14

# Comma-separated listing IDs. Leave blank to scan every active listed property.
LISTING_IDS=

# Manual blocks only by default. See README.md before changing this.
OPENABLE_BLOCK_TYPES=m
